{
  "bot": {
    "name": "olixbot",
    "version": "1.0"0
    "mode": "security"
  },
  "monitoring": {
    "enabled": true,
    "track_messages": true,
    "track_logins": true,
    "track_commands": true
  },
  "detection": {
    "spam": {
      "enabled": true,
      "max_messages_per_10s": 5,
      "action": "warn"
    },
    "raid": {
      "enabled": true,
      "max_joins_per_minute": 10,
      "action": "lock_channel"
    },
    "suspicious_links": {
      "enabled": true,
      "blacklist": [
        "bit.ly",
        "tinyurl.com",
        "malicious-site.com"
      ],
      "action": "delete_message"
    },
    "bruteforce": {
      "enabled": true,
      "max_failed_logins": 3,
      "action": "temporary_ban"
    }
  },
  "alerts": {
    "enabled": true,
    "admin_contact": "+50946358257",
    "log_channel": "security-logs",
    "notify_on": [
      "spam",
      "raid",
      "suspicious_links",
      "bruteforce"
    ]
  },
  "response": {
    "auto_warn": true,
    "auto_kick": false,
    "auto_ban": true,
    "lockdown_mode": true
  },
  "whitelist": {
    "users": [
      "admin1",
      "admin2"
    ],
    "roles": [
      "moderator"
    ]
  },
  "blacklist": {
    "users": [],
    "words": [
      "hack",
      "attack",
      "ddos"
    ]
  }
}